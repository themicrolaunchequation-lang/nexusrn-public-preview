{
  "rewrites": [
    {
      "source": "/demo",
      "destination": "/public-demo/index.html"
    },
    {
      "source": "/access",
      "destination": "/pricing/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "no-referrer"
        }
      ]
    }
  ]
}